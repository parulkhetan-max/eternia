---
interface Feature {
  icon: string;
  title: string;
  description: string;
  learnMoreLink: string;
}

interface Props {
  title: string;
  subtitle?: string;
  features: Feature[];
}

const { title, subtitle, features } = Astro.props;
---

<section class="py-24 px-6 bg-white">
  <div class="max-w-7xl mx-auto">
    {/* Header */}
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[var(--color-dark)]">{title}</h2>
      {subtitle && (
        <div class="w-24 h-1 bg-[var(--color-blue)] mx-auto"></div>
      )}
    </div>

    {/* Carousel Container */}
    <div class="relative">
      <div id="featuresCarousel" class="flex overflow-hidden">
        <div class="flex transition-transform duration-500 ease-in-out w-full" style="transform: translateX(0)">
          {features.map((feature, index) => (
            <div class="min-w-full md:min-w-1/2 lg:min-w-1/4 px-4" data-feature-index={index}>
              <div class={`h-full p-8 rounded-lg border-2 transition-all duration-300 ${
                index === 0 
                  ? 'bg-[var(--color-blue)] border-[var(--color-blue)] text-white' 
                  : 'bg-white border-gray-300 text-[var(--color-dark)] hover:border-[var(--color-blue)]'
              }`}>
                {/* Icon */}
                <div class={`mb-6 text-5xl ${index === 0 ? 'text-white' : 'text-[var(--color-green)]'}`}>
                  {feature.icon}
                </div>

                {/* Title */}
                <h3 class="text-xl font-bold mb-4">{feature.title}</h3>

                {/* Description */}
                <p class={`text-sm leading-relaxed mb-6 ${index === 0 ? 'text-gray-100' : 'text-gray-600'}`}>
                  {feature.description}
                </p>

                {/* Learn More Link */}
                <a 
                  href={feature.learnMoreLink}
                  class={`inline-block underline transition-colors duration-300 ${
                    index === 0 
                      ? 'text-white hover:text-gray-200' 
                      : 'text-[var(--color-blue)] hover:text-[var(--color-green)]'
                  }`}
                >
                  Learn More
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Navigation Arrows and Indicators */}
      <div class="flex justify-center items-center gap-6 mt-8">
        <button 
          id="carouselPrev"
          class="flex items-center justify-center w-10 h-10 rounded-full bg-gray-200 hover:bg-[var(--color-blue)] text-gray-600 hover:text-white transition-all duration-300"
          aria-label="Previous features"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        <div id="indicatorsContainer" class="flex gap-2">
          {features.slice(0, 3).map((_, index) => (
            <button
              class={`carousel-indicator w-3 h-3 rounded-full transition-all duration-300 ${
                index === 0 
                  ? 'bg-[var(--color-blue)] w-8' 
                  : 'bg-gray-300 hover:bg-gray-400'
              }`}
              data-index={index}
              aria-label={`Go to feature ${index + 1}`}
            ></button>
          ))}
        </div>

        <button 
          id="carouselNext"
          class="flex items-center justify-center w-10 h-10 rounded-full bg-gray-200 hover:bg-[var(--color-blue)] text-gray-600 hover:text-white transition-all duration-300"
          aria-label="Next features"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const carousel = document.getElementById('featuresCarousel');
  const carouselInner = carousel?.querySelector('div') as HTMLElement;
  const indicatorsContainer = document.getElementById('indicatorsContainer');
  const prevBtn = document.getElementById('carouselPrev') as HTMLButtonElement;
  const nextBtn = document.getElementById('carouselNext') as HTMLButtonElement;
  
  let currentIndex = 0;
  const totalItems = carousel?.querySelectorAll('[data-feature-index]').length || 0;
  const maxVisibleIndicators = 3;

  function updateArrowStates() {
    // Disable prev button if at the start
    if (prevBtn) {
      if (currentIndex === 0) {
        prevBtn.disabled = true;
        prevBtn.classList.add('opacity-50', 'cursor-not-allowed');
        prevBtn.classList.remove('hover:bg-[var(--color-blue)]', 'hover:text-white');
      } else {
        prevBtn.disabled = false;
        prevBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        prevBtn.classList.add('hover:bg-[var(--color-blue)]', 'hover:text-white');
      }
    }

    // Disable next button if at the end
    if (nextBtn) {
      if (currentIndex === totalItems - 1) {
        nextBtn.disabled = true;
        nextBtn.classList.add('opacity-50', 'cursor-not-allowed');
        nextBtn.classList.remove('hover:bg-[var(--color-blue)]', 'hover:text-white');
      } else {
        nextBtn.disabled = false;
        nextBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        nextBtn.classList.add('hover:bg-[var(--color-blue)]', 'hover:text-white');
      }
    }
  }

  function updateIndicators() {
    // Clear existing indicators
    indicatorsContainer!.innerHTML = '';

    // Calculate which indicators to show
    let startIndex = Math.max(0, currentIndex - 1);
    let endIndex = Math.min(totalItems, startIndex + maxVisibleIndicators);

    // If we're near the end, adjust to always show 3
    if (endIndex - startIndex < maxVisibleIndicators) {
      startIndex = Math.max(0, endIndex - maxVisibleIndicators);
    }

    // Create and add indicators
    for (let i = startIndex; i < endIndex; i++) {
      const indicator = document.createElement('button');
      indicator.className = `carousel-indicator w-3 h-3 rounded-full transition-all duration-300 ${
        i === currentIndex
          ? 'bg-[var(--color-blue)] w-8'
          : 'bg-gray-300 hover:bg-gray-400'
      }`;
      indicator.setAttribute('data-index', String(i));
      indicator.setAttribute('aria-label', `Go to feature ${i + 1}`);
      indicator.addEventListener('click', () => goToSlide(i));
      indicatorsContainer!.appendChild(indicator);
    }
  }

  function updateCarousel() {
    if (carouselInner) {
      const offset = -(currentIndex * 100);
      carouselInner.style.transform = `translateX(${offset}%)`;
    }
    updateIndicators();
    updateArrowStates();
  }

  function nextSlide() {
    if (currentIndex < totalItems - 1) {
      currentIndex++;
      updateCarousel();
    }
  }

  function prevSlide() {
    if (currentIndex > 0) {
      currentIndex--;
      updateCarousel();
    }
  }

  function goToSlide(index: number) {
    currentIndex = index;
    updateCarousel();
  }

  // Event listeners
  prevBtn?.addEventListener('click', prevSlide);
  nextBtn?.addEventListener('click', nextSlide);

  // Initialize
  updateCarousel();

  // Handle window resize
  window.addEventListener('resize', () => {
    updateCarousel();
  });
</script>
